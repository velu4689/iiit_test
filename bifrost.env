# ── Bifrost Security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BIFROST_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32-output

# ── Bifrost Admin Dashboard Login ─────────────────────────────────────────────
BIFROST_ADMIN_USERNAME=admin
BIFROST_ADMIN_PASSWORD=replace-with-strong-password

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Minimum version: PostgreSQL 16, encoding MUST be UTF8
BIFROST_PG_HOST=postgres        # Use service name in Docker Compose, or your RDS hostname
BIFROST_PG_PORT=5432
BIFROST_PG_USER=bifrost
BIFROST_PG_PASSWORD=replace-with-strong-db-password
BIFROST_PG_DBNAME=bifrost
BIFROST_PG_SSLMODE=disable      # Set to "require" when using RDS or TLS-enabled Postgres

# ── AWS Region ────────────────────────────────────────────────────────────────
# Credentials come from the attached IAM role — no keys needed here
AWS_REGION=us-east-1
